<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Linkly administration dashboard.">
    <title>Admin dashboard — Linkly</title>
    <link rel="stylesheet" href="/css/admin.css">
    <script src="/js/script.js" defer></script>
</head>
<body>
    <%
        const totalUsers = users ? users.length : 0;
        const totalUrls = users ? users.reduce((sum, account) => sum + account.totalUrls, 0) : 0;
        const totalVisits = users ? users.reduce((sum, account) => sum + account.totalVisits, 0) : 0;
        const adminInitial = user.email ? user.email.charAt(0).toUpperCase() : "A";
    %>

    <aside class="sidebar" id="sidebar">
        <a class="brand" href="/admin/urls">
            <span class="brand-mark">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                </svg>
            </span>
            Linkly
        </a>

        <p class="nav-label">Workspace</p>
        <nav class="side-nav">
            <a class="side-link active" href="/admin/urls">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                Overview
            </a>
            <a class="side-link" href="#users">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                Users
            </a>
            <a class="side-link" href="#users">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                Links
            </a>
        </nav>

        <div class="sidebar-bottom">
            <div class="admin-profile">
                <span class="avatar"><%= adminInitial %></span>
                <div>
                    <strong>Administrator</strong>
                    <span title="<%= user.email %>"><%= user.email %></span>
                </div>
            </div>
            <form action="/user/logout" method="POST">
                <button class="logout-button" type="submit">Sign out</button>
            </form>
        </div>
    </aside>

    <div class="main">
        <header class="topbar">
            <div class="topbar-title">
                <button class="mobile-menu" type="button" aria-label="Toggle sidebar">
                    <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
                </button>
                <strong>Control center</strong>
                <span class="admin-badge">Admin</span>
            </div>

            <div class="topbar-actions">
                <div class="search-wrap">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m20 20-4-4"/></svg>
                    <input class="search-input" type="search" id="userSearch" placeholder="Search users or email...">
                </div>
                <a class="view-site" href="/login">View site ↗</a>
            </div>
        </header>

        <main class="content">
            <header class="page-head">
                <div>
                    <h1>Dashboard overview</h1>
                    <p>Monitor users, short links, and total engagement across Linkly.</p>
                </div>
                <span class="date-chip">Updated <%= new Date().toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) %></span>
            </header>

            <section class="stats-grid" aria-label="Platform statistics">
                <article class="stat-card stat-card-links">
                    <div class="stat-top">
                        <span class="stat-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/></svg>
                        </span>
                        <span class="stat-trend">Active accounts</span>
                    </div>
                    <strong><%= totalUsers %></strong>
                    <span>Registered users</span>
                </article>

                <article class="stat-card stat-card-clicks">
                    <div class="stat-top">
                        <span class="stat-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                        </span>
                        <span class="stat-trend">All time</span>
                    </div>
                    <strong><%= totalUrls %></strong>
                    <span>Short links created</span>
                </article>

                <article class="stat-card stat-card-users">
                    <div class="stat-top">
                        <span class="stat-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="m7 16 4-5 4 3 5-7"/></svg>
                        </span>
                        <span class="stat-trend">Total traffic</span>
                    </div>
                    <strong><%= totalVisits %></strong>
                    <span>Recorded link visits</span>
                </article>
            </section>

            <section class="section-card" id="users">
                <div class="section-head">
                    <div>
                        <h2>User activity</h2>
                        <p>Expand an account to inspect its links and engagement.</p>
                    </div>
                    <span class="result-count" id="resultCount"><%= totalUsers %> users</span>
                </div>

                <% if (users && users.length > 0) { %>
                    <div class="users-list" id="usersList">
                        <% users.forEach((account, index) => { %>
                            <article class="user-card <%= index === 0 ? "open" : "" %>" data-search="<%= `${account.name} ${account.email}`.toLowerCase() %>">
                                <div class="user-summary">
                                    <div class="user-identity">
                                        <span class="user-avatar"><%= account.name ? account.name.charAt(0).toUpperCase() : "U" %></span>
                                        <div>
                                            <strong><%= account.name %></strong>
                                            <span><%= account.email %></span>
                                        </div>
                                    </div>
                                    <div class="user-metric">
                                        <strong><%= account.totalUrls %></strong>
                                        <span>Short links</span>
                                    </div>
                                    <div class="user-metric">
                                        <strong><%= account.totalVisits %></strong>
                                        <span>Total visits</span>
                                    </div>
                                    <button class="toggle-button" type="button" aria-label="Toggle user details">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
                                    </button>
                                </div>

                                <div class="user-details">
                                    <% if (account.urls && account.urls.length > 0) { %>
                                        <div class="table-wrap">
                                            <table>
                                                <thead>
                                                    <tr>
                                                        <th>Short link</th>
                                                        <th>Destination</th>
                                                        <th>Visits</th>
                                                        <th>Created</th>
                                                        <th>Copy</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% account.urls.forEach(url => { %>
                                                        <% const fullShortUrl = `${baseUrl}/url/${url.Shortid}`; %>
                                                        <tr>
                                                            <td><a class="short-link" href="<%= fullShortUrl %>" target="_blank" rel="noopener noreferrer">/url/<%= url.Shortid %></a></td>
                                                            <td class="destination" title="<%= url.RedirectUrl %>"><%= url.RedirectUrl %></td>
                                                            <td><span class="visit-badge"><%= url.VisitHistory.length %></span></td>
                                                            <td><%= new Date(url.createdAt).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) %></td>
                                                            <td><button class="copy-button" type="button" data-copy="<%= fullShortUrl %>">Copy</button></td>
                                                        </tr>
                                                    <% }); %>
                                                </tbody>
                                            </table>
                                        </div>
                                    <% } else { %>
                                        <div class="user-empty">This user has not created any short links yet.</div>
                                    <% } %>
                                </div>
                            </article>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="global-empty">
                        <div class="global-empty-icon">◎</div>
                        <h3>No users yet</h3>
                        <p>New user accounts will appear here after signup.</p>
                    </div>
                <% } %>
            </section>
        </main>
    </div>

</body>
</html>
